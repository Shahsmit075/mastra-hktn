# Runbook Sentinel — Environment Variables
# Copy this file to apps/api/.env and fill in values
# NEVER commit the actual .env file

# ─── LLM: Featherless AI ──────────────────────────────────────────────────────
FEATHERLESS_API_KEY=
FEATHERLESS_BASE_URL=https://api.featherless.ai/v1
FEATHERLESS_MODEL=Qwen/Qwen2.5-72B-Instruct
FEATHERLESS_EMBED_MODEL=nomic-ai/nomic-embed-text-v1.5

# ─── Qdrant ───────────────────────────────────────────────────────────────────
# Local (Docker): http://localhost:6333 with no API key
# Cloud: https://your-cluster.qdrant.io with API key
QDRANT_URL=https://99feaf85-b034-49e3-9199-c24ebe2e9158.australia-southeast1-0.gcp.cloud.qdrant.io
QDRANT_API_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJhY2Nlc3MiOiJtIiwic3ViamVjdCI6ImFwaS1rZXk6ZmQ2YTgzZmItNDUzOC00MzM5LWE4OTYtODY4ZGVkZTk5MWVkIn0.fn_21FFhnfMbZO3Z2NY3wUyUMFYNngM6c7l2O8WTJz8


# ─── Enkrypt AI ───────────────────────────────────────────────────────────────
ENKRYPT_API_KEY=2O9VwhLicM6kXMNgr0qRfbzWbRmKwxTU
ENKRYPT_BASE_URL=https://api.enkryptai.com

# ─── PostgreSQL ───────────────────────────────────────────────────────────────
# Local (Docker): postgresql://sentinel:sentinel_dev_pass@localhost:5432/runbook_sentinel
# Supabase: postgresql://postgres:[password]@db.[ref].supabase.co:5432/postgres
DATABASE_URL=postgresql://sentinel:sentinel_dev_pass@localhost:5432/runbook_sentinel

# ─── Redis ────────────────────────────────────────────────────────────────────
# Local (Docker): redis://localhost:6379
# Upstash: redis://default:[password]@[host]:[port]
REDIS_URL=redis://localhost:6379

# ─── Auth ─────────────────────────────────────────────────────────────────────
# Generate with: openssl rand -base64 32
JWT_SECRET=
JWT_EXPIRES_IN=15m

# ─── App ──────────────────────────────────────────────────────────────────────
PORT=3001
NODE_ENV=development
LOG_LEVEL=info

# ─── OpenTelemetry ────────────────────────────────────────────────────────────
OTEL_SERVICE_NAME=runbook-sentinel-api
# Set to "true" to export to Honeycomb; leave "false" for local console output
OTEL_EXPORT_ENABLED=false
OTEL_EXPORTER_OTLP_ENDPOINT=https://api.honeycomb.io
# Format: x-honeycomb-team=YOUR_API_KEY
OTEL_EXPORTER_OTLP_HEADERS=

# ─── Frontend (Next.js) ───────────────────────────────────────────────────────
# These go in apps/web/.env.local
NEXT_PUBLIC_API_URL=http://localhost:3001
# Demo JWT token for frontend (generate with /v1/auth/demo-token endpoint)
NEXT_PUBLIC_DEMO_TOKEN=

# ─── CORS ─────────────────────────────────────────────────────────────────────
ALLOWED_ORIGINS=http://localhost:3000
